# Copy to server/.env for local dev. Real values are managed by Coolify in production.

# Database (Phase A)
DATABASE_URL=postgres://museiris:museiris_dev@localhost:5432/museiris

# Server (Phase A)
PORT=3001
NODE_ENV=development

# Admin auth (Phase B)
# Generate the hash with: npm --prefix server run hash-password -- yourpassword
ADMIN_PASSWORD_HASH=
# Any long random string; rotate to invalidate all existing sessions.
JWT_SECRET=
# Set to true behind HTTPS (production).
COOKIE_SECURE=false
